<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Appender console synchrone (cible finale des logs) -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %5p ${PID:- } --- [%15.15t] %-40.40logger{39} : %m%n</pattern>
        </encoder>
    </appender>

    <!--
        AsyncAppender : découple l'écriture des logs du thread applicatif.
        - queueSize=512     : buffer en mémoire avant écriture effective
        - discardingThreshold=0 : ne jamais perdre de messages (même TRACE/DEBUG)
        - includeCallerData=false : perf — ne pas résoudre la stack trace d'appel
        Justification : les logs synchrones bloquent les threads sur l'I/O console/fichier.
        En prod, cela crée des micro-pauses mesurables sur les requêtes HTTP.
    -->
    <appender name="ASYNC" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <includeCallerData>false</includeCallerData>
        <appender-ref ref="CONSOLE"/>
    </appender>

    <!-- Logs applicatifs en DEBUG pour faciliter le dev et l'audit -->
    <logger name="com.example" level="DEBUG"/>

    <!-- SQL Hibernate en DEBUG (visible uniquement si show-sql=true dans properties) -->
    <logger name="org.hibernate.SQL" level="DEBUG"/>

    <!-- Niveau racine : INFO via l'appender asynchrone -->
    <root level="INFO">
        <appender-ref ref="ASYNC"/>
    </root>

</configuration>
